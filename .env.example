# 2R Fusion - Environment Variables Template
# Copy this file to .env.local and fill in your values

# ==============================================================================
# CORE APPLICATION
# ==============================================================================

# Database connection string
# Development: file:./prisma/dev.db
# Production: postgresql://user:password@host:5432/database
DATABASE_URL="file:./prisma/dev.db"

# NextAuth.js configuration
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-minimum-32-characters"

# NextAuth.js allowed URLs
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXTAUTH_URL="http://localhost:3000"

# Node environment
# Options: development, production, test
NODE_ENV="development"

# ==============================================================================
# OPTIONAL: PAYMENT PROCESSING
# ==============================================================================

# Stripe Configuration (Phase 2)
# STRIPE_PUBLIC_KEY="pk_test_51234567890abcdef"
# STRIPE_SECRET_KEY="sk_test_1234567890abcdef"

# CMI Configuration (Phase 2 - Morocco gateway)
# CMI_MERCHANT_ID="your-merchant-id"
# CMI_API_KEY="your-api-key"

# ==============================================================================
# OPTIONAL: EMAIL NOTIFICATIONS
# ==============================================================================

# SendGrid Configuration (Phase 2)
# SENDGRID_API_KEY="SG.1234567890abcdefghijklmnopqrstuv"
# SENDGRID_FROM_EMAIL="noreply@2rfusion.ma"

# ==============================================================================
# OPTIONAL: SMS NOTIFICATIONS
# ==============================================================================

# Twilio Configuration (Phase 2)
# TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_AUTH_TOKEN="your-auth-token"
# TWILIO_PHONE_NUMBER="+212612345678"

# ==============================================================================
# OPTIONAL: ANALYTICS
# ==============================================================================

# Google Analytics (Phase 2+)
# GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"

# ==============================================================================
# OPTIONAL: THIRD-PARTY INTEGRATIONS
# ==============================================================================

# External APIs (Phase 3+)
# BARCODE_API_KEY="your-barcode-database-key"
# WEATHER_API_KEY="your-weather-service-key"

# ==============================================================================
# NOTES
# ==============================================================================
# 
# SECURITY:
# - NEVER commit .env.local to version control
# - Use this .env.example file as a template only
# - In production, use platform-specific secrets management:
#   * Vercel: Environment Variables dashboard
#   * AWS: Secrets Manager
#   * Railway: Variables panel
#   * Heroku: Config Vars
#
# DEVELOPMENT:
# - Copy .env.example to .env.local
# - Fill in required variables (DATABASE_URL, NEXTAUTH_SECRET, NEXTAUTH_URL)
# - Run: npm install && npx prisma db push && npx prisma db seed
# - Start: npm run dev
#
# PRODUCTION:
# - Set DATABASE_URL to PostgreSQL connection
# - Generate NEW NEXTAUTH_SECRET (don't reuse development secret)
# - Set NEXTAUTH_URL to your production domain
# - Set up payment gateway (Stripe/CMI) credentials
# - Set up email service (SendGrid) credentials
#
# TESTING:
# - Create .env.test with test database path
# - DATABASE_URL="file:./prisma/test.db"
# - Run: npm test
#
