generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// AUTH & USERS
// ============================================================

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         String    @default("STAFF") // SUPER_ADMIN, ADMIN, MANAGER, HOST, CHEF, WAITER, BARTENDER, STAFF
  isActive     Boolean   @default(true)
  avatarUrl    String?
  phone        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  employee       Employee?
  auditLogs      AuditLog[]
  alerts         Alert[]
  anomalyReviews AnomalyReview[]
  sessions       Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// EMPLOYEES & SHIFTS
// ============================================================

model Employee {
  id               String   @id @default(cuid())
  userId           String   @unique
  firstName        String
  lastName         String
  department       String
  position         String
  hireDate         DateTime
  hourlyRate       Float?
  phone            String?
  emergencyContact String?
  isActive         Boolean  @default(true)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id])
  shifts           Shift[]
  orderTickets     OrderTicket[]
  anomalies        Anomaly[]
  performanceNotes PerformanceNote[]
}

model Shift {
  id         String    @id @default(cuid())
  employeeId String
  startTime  DateTime
  endTime    DateTime?
  status     String    @default("SCHEDULED")
  notes      String?
  createdAt  DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
}

model PerformanceNote {
  id         String   @id @default(cuid())
  employeeId String
  authorId   String
  note       String
  type       String   @default("GENERAL")
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
}

// ============================================================
// VENUE & TABLES
// ============================================================

model Venue {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  address     String?
  city        String?
  phone       String?
  email       String?
  description String?
  timezone    String   @default("Africa/Casablanca")
  currency    String   @default("MAD")
  isActive    Boolean  @default(true)
  settings    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tables       Table[]
  privateRooms PrivateRoom[]
  menus        Menu[]
}

model Table {
  id        String   @id @default(cuid())
  venueId   String
  number    Int
  zone      String   @default("MAIN")
  capacity  Int
  status    String   @default("AVAILABLE")
  qrCode    String?
  isActive  Boolean  @default(true)
  posX      Float?
  posY      Float?
  createdAt DateTime @default(now())

  venue        Venue         @relation(fields: [venueId], references: [id])
  reservations Reservation[]
  orderTickets OrderTicket[]
}

model PrivateRoom {
  id          String   @id @default(cuid())
  venueId     String
  name        String
  capacity    Int
  minSpend    Float?
  description String?
  amenities   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  venue        Venue         @relation(fields: [venueId], references: [id])
  reservations Reservation[]
}

// ============================================================
// GUESTS & CRM
// ============================================================

model Guest {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  email         String?
  phone         String?
  dateOfBirth   DateTime?
  anniversary   DateTime?
  company       String?
  notes         String?
  preferences   String?
  totalVisits   Int       @default(0)
  totalSpent    Float     @default(0)
  averageSpend  Float     @default(0)
  lastVisitAt   DateTime?
  tier          String    @default("NEW")
  source        String?
  isActive      Boolean   @default(true)
  riskScore     Float     @default(0)
  loyaltyPoints Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tags         GuestTag[]
  reservations Reservation[]
  complaints   Complaint[]
  orderTickets OrderTicket[]
}

model GuestTag {
  id      String @id @default(cuid())
  guestId String
  tag     String

  guest Guest @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@unique([guestId, tag])
}

model Complaint {
  id          String    @id @default(cuid())
  guestId     String
  type        String
  description String
  severity    String    @default("LOW")
  status      String    @default("OPEN")
  resolution  String?
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  guest Guest @relation(fields: [guestId], references: [id])
}

// ============================================================
// RESERVATIONS
// ============================================================

model Reservation {
  id               String   @id @default(cuid())
  guestId          String?
  tableId          String?
  privateRoomId    String?
  venueId          String?
  guestName        String
  guestEmail       String?
  guestPhone       String?
  partySize        Int
  date             DateTime
  timeSlot         String
  endTime          String?
  status           String   @default("CONFIRMED")
  occasion         String?
  specialRequests  String?
  isVip            Boolean  @default(false)
  isPrivateRoom    Boolean  @default(false)
  source           String   @default("WEBSITE")
  confirmationCode String?  @unique
  notes            String?
  noShowCount      Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  guest       Guest?       @relation(fields: [guestId], references: [id])
  table       Table?       @relation(fields: [tableId], references: [id])
  privateRoom PrivateRoom? @relation(fields: [privateRoomId], references: [id])
}

// ============================================================
// MENUS & DISHES
// ============================================================

model Menu {
  id            String    @id @default(cuid())
  venueId       String
  name          String
  slug          String    @unique
  description   String?
  type          String    @default("MAIN")
  isActive      Boolean   @default(true)
  isVipOnly     Boolean   @default(false)
  sortOrder     Int       @default(0)
  availableFrom DateTime?
  availableTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  venue      Venue          @relation(fields: [venueId], references: [id])
  categories MenuCategory[]
}

model MenuCategory {
  id            String   @id @default(cuid())
  menuId        String
  name          String
  nameFr        String?
  nameAr        String?
  description   String?
  descriptionFr String?
  slug          String
  imageUrl      String?
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  menu   Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  dishes Dish[]
}

model Dish {
  id                String   @id @default(cuid())
  categoryId        String
  name              String
  nameFr            String?
  nameAr            String?
  description       String?
  descriptionFr     String?
  slug              String   @unique
  price             Float
  compareAtPrice    Float?
  costPrice         Float?
  imageUrl          String?
  allergens         String?
  ingredients       String?
  dietaryTags       String?
  spiceLevel        Int?
  prepTimeMinutes   Int?
  isAvailable       Boolean  @default(true)
  isChefSpecial     Boolean  @default(false)
  isSeasonal        Boolean  @default(false)
  isNew             Boolean  @default(false)
  isVipOnly         Boolean  @default(false)
  pairingSuggestion String?
  upsellDishIds     String?
  sortOrder         Int      @default(0)
  totalOrdered      Int      @default(0)
  rating            Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  category   MenuCategory @relation(fields: [categoryId], references: [id])
  recipe     Recipe?
  orderItems OrderItem[]
}

// ============================================================
// RECIPES & INGREDIENTS
// ============================================================

model Recipe {
  id              String   @id @default(cuid())
  dishId          String   @unique
  instructions    String?
  prepTimeMinutes Int?
  cookTimeMinutes Int?
  servings        Int      @default(1)
  difficulty      String   @default("MEDIUM")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  dish              Dish               @relation(fields: [dishId], references: [id])
  recipeIngredients RecipeIngredient[]
}

model RecipeIngredient {
  id              String  @id @default(cuid())
  recipeId        String
  inventoryItemId String?
  name            String
  quantity        Float
  unit            String
  isOptional      Boolean @default(false)
  notes           String?
  costPerUnit     Float?

  recipe        Recipe         @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id])
}

// ============================================================
// INVENTORY
// ============================================================

model InventoryItem {
  id              String    @id @default(cuid())
  name            String
  sku             String?   @unique
  barcode         String?   @unique
  category        String
  unit            String
  currentStock    Float     @default(0)
  minStock        Float     @default(0)
  maxStock        Float?
  parLevel        Float?
  costPerUnit     Float     @default(0)
  isPerishable    Boolean   @default(false)
  shelfLifeDays   Int?
  storageLocation String?
  isActive        Boolean   @default(true)
  lastCountedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  recipeIngredients  RecipeIngredient[]
  stockBatches       StockBatch[]
  stockMovements     StockMovement[]
  supplierProducts   SupplierProduct[]
  spoilageEvents     SpoilageEvent[]
  purchaseOrderItems PurchaseOrderItem[]
}

model StockBatch {
  id              String    @id @default(cuid())
  inventoryItemId String
  batchNumber     String?
  quantity        Float
  remainingQty    Float
  costPerUnit     Float
  receivedAt      DateTime  @default(now())
  expiresAt       DateTime?
  bestBeforeAt    DateTime?
  supplierId      String?
  deliveryId      String?
  status          String    @default("ACTIVE")
  notes           String?
  createdAt       DateTime  @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  supplier      Supplier?     @relation(fields: [supplierId], references: [id])
}

model StockMovement {
  id              String   @id @default(cuid())
  inventoryItemId String
  type            String
  quantity        Float
  previousStock   Float
  newStock        Float
  reason          String?
  referenceType   String?
  referenceId     String?
  performedBy     String?
  shiftId         String?
  notes           String?
  createdAt       DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
}

model SpoilageEvent {
  id              String   @id @default(cuid())
  inventoryItemId String
  quantity        Float
  unit            String
  reason          String
  estimatedValue  Float
  discoveredBy    String?
  shiftId         String?
  actionTaken     String?
  suggestedDishes String?
  notes           String?
  createdAt       DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
}

// ============================================================
// SUPPLIERS
// ============================================================

model Supplier {
  id               String   @id @default(cuid())
  name             String
  contactName      String?
  email            String?
  phone            String?
  address          String?
  city             String?
  taxId            String?
  paymentTerms     String?
  deliveryDays     String?
  leadTimeDays     Int      @default(1)
  rating           Float    @default(0)
  reliabilityScore Float    @default(100)
  isActive         Boolean  @default(true)
  isPreferred      Boolean  @default(false)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  products       SupplierProduct[]
  purchaseOrders PurchaseOrder[]
  invoices       Invoice[]
  stockBatches   StockBatch[]
  deliveries     Delivery[]
}

model SupplierProduct {
  id              String    @id @default(cuid())
  supplierId      String
  inventoryItemId String
  supplierSku     String?
  unitPrice       Float
  minOrderQty     Float?
  leadTimeDays    Int?
  isPreferred     Boolean   @default(false)
  lastOrderedAt   DateTime?
  priceHistory    String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  supplier      Supplier      @relation(fields: [supplierId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@unique([supplierId, inventoryItemId])
}

// ============================================================
// PURCHASE ORDERS & DELIVERIES
// ============================================================

model PurchaseOrder {
  id              String    @id @default(cuid())
  supplierId      String
  orderNumber     String    @unique
  status          String    @default("DRAFT")
  totalAmount     Float     @default(0)
  expectedDate    DateTime?
  notes           String?
  approvedBy      String?
  approvedAt      DateTime?
  submittedAt     DateTime?
  isForecastBased Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  items      PurchaseOrderItem[]
  deliveries Delivery[]
  invoices   Invoice[]
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  inventoryItemId String
  quantity        Float
  unitPrice       Float
  receivedQty     Float   @default(0)
  notes           String?

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
}

model Delivery {
  id               String    @id @default(cuid())
  purchaseOrderId  String?
  supplierId       String
  deliveryNumber   String?
  status           String    @default("PENDING")
  expectedAt       DateTime?
  receivedAt       DateTime?
  receivedBy       String?
  temperatureCheck Float?
  qualityNotes     String?
  discrepancies    String?
  isLate           Boolean   @default(false)
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
}

// ============================================================
// INVOICES & PAYMENTS
// ============================================================

model Invoice {
  id              String    @id @default(cuid())
  supplierId      String?
  purchaseOrderId String?
  invoiceNumber   String    @unique
  type            String    @default("SUPPLIER")
  status          String    @default("PENDING")
  subtotal        Float
  taxAmount       Float     @default(0)
  totalAmount     Float
  paidAmount      Float     @default(0)
  currency        String    @default("MAD")
  dueDate         DateTime?
  paidAt          DateTime?
  approvedBy      String?
  approvedAt      DateTime?
  attachmentUrl   String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  payments      Payment[]
}

model Payment {
  id         String   @id @default(cuid())
  invoiceId  String
  amount     Float
  method     String
  reference  String?
  paidAt     DateTime @default(now())
  notes      String?
  recordedBy String?
  createdAt  DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

// ============================================================
// ORDERS
// ============================================================

model OrderTicket {
  id                  String    @id @default(cuid())
  tableId             String?
  guestId             String?
  employeeId          String?
  ticketNumber        String    @unique
  status              String    @default("OPEN")
  type                String    @default("DINE_IN")
  subtotal            Float     @default(0)
  discountAmount      Float     @default(0)
  discountReason      String?
  taxAmount           Float     @default(0)
  totalAmount         Float     @default(0)
  tipAmount           Float     @default(0)
  paymentMethod       String?
  paymentStatus       String    @default("UNPAID")
  isComplimentary     Boolean   @default(false)
  complimentaryReason String?
  isVoid              Boolean   @default(false)
  voidReason          String?
  voidedBy            String?
  voidedAt            DateTime?
  guestCount          Int       @default(1)
  notes               String?
  kitchenNotes        String?
  openedAt            DateTime  @default(now())
  closedAt            DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  table    Table?      @relation(fields: [tableId], references: [id])
  guest    Guest?      @relation(fields: [guestId], references: [id])
  employee Employee?   @relation(fields: [employeeId], references: [id])
  items    OrderItem[]
}

model OrderItem {
  id                  String    @id @default(cuid())
  orderId             String
  dishId              String
  quantity            Int
  unitPrice           Float
  totalPrice          Float
  status              String    @default("PENDING")
  modifiers           String?
  isVoid              Boolean   @default(false)
  voidReason          String?
  voidedBy            String?
  isComplimentary     Boolean   @default(false)
  complimentaryReason String?
  notes               String?
  firedAt             DateTime?
  readyAt             DateTime?
  servedAt            DateTime?
  createdAt           DateTime  @default(now())

  order OrderTicket @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dish  Dish        @relation(fields: [dishId], references: [id])
}

// ============================================================
// ANOMALY DETECTION
// ============================================================

model Anomaly {
  id            String    @id @default(cuid())
  type          String
  severity      String    @default("LOW")
  riskScore     Float     @default(0)
  employeeId    String?
  description   String
  details       String?
  evidence      String?
  referenceType String?
  referenceId   String?
  status        String    @default("NEW")
  assignedTo    String?
  resolvedAt    DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  employee Employee?       @relation(fields: [employeeId], references: [id])
  reviews  AnomalyReview[]
}

model AnomalyReview {
  id         String   @id @default(cuid())
  anomalyId  String
  reviewerId String
  action     String
  notes      String?
  createdAt  DateTime @default(now())

  anomaly  Anomaly @relation(fields: [anomalyId], references: [id], onDelete: Cascade)
  reviewer User    @relation(fields: [reviewerId], references: [id])
}

// ============================================================
// FORECASTS & RECOMMENDATIONS
// ============================================================

model Forecast {
  id          String    @id @default(cuid())
  type        String
  period      String
  targetDate  DateTime
  status      String    @default("GENERATED")
  confidence  Float     @default(0)
  data        String
  methodology String?
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())

  recommendations Recommendation[]
}

model Recommendation {
  id             String    @id @default(cuid())
  forecastId     String?
  type           String
  priority       String    @default("MEDIUM")
  title          String
  description    String
  actionRequired String?
  rationale      String?
  data           String?
  status         String    @default("PENDING")
  decidedBy      String?
  decidedAt      DateTime?
  createdAt      DateTime  @default(now())

  forecast Forecast? @relation(fields: [forecastId], references: [id])
}

// ============================================================
// ALERTS & AUDIT
// ============================================================

model Alert {
  id          String    @id @default(cuid())
  type        String
  severity    String    @default("INFO")
  title       String
  message     String
  data        String?
  isRead      Boolean   @default(false)
  isDismissed Boolean   @default(false)
  userId      String?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  oldValue   String?
  newValue   String?
  ipAddress  String?
  userAgent  String?
  notes      String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

// ============================================================
// SETTINGS
// ============================================================

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("STRING")
  category  String   @default("GENERAL")
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
