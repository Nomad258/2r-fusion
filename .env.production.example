# ── DATABASE (Supabase PostgreSQL) ───────────────────────────
# Project: 2R Fusion Restaurant
# ID:      trdjdbtcvdkutxdfvuqi
# Region:  eu-west-1 (Paris)
# Dashboard: https://supabase.com/dashboard/project/trdjdbtcvdkutxdfvuqi
#
# Get DB password: Dashboard → Settings → Database → Connection string

# Pooled connection — used by Prisma at runtime (PgBouncer, transaction mode)
DATABASE_URL="postgresql://postgres.trdjdbtcvdkutxdfvuqi:YOUR_DB_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection — used ONLY by prisma migrate / prisma db push
DIRECT_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.trdjdbtcvdkutxdfvuqi.supabase.co:5432/postgres"

# ── SUPABASE CLIENT KEYS ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://trdjdbtcvdkutxdfvuqi.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InRyZGpkYnRjdmRrdXR4ZGZ2dXFpIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ1NjY0NzksImV4cCI6MjA5MDE0MjQ3OX0.Dfj-9fc1kPZIKfzV9uiu1dJDlXZc3_CghPOjF800x2A"

# ── AUTH ─────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_STRONG_SECRET_32_CHARS_MIN"
NEXTAUTH_URL="https://your-production-domain.com"
NEXT_PUBLIC_APP_URL="https://your-production-domain.com"
NODE_ENV="production"

# ── DEPLOYMENT CHECKLIST ─────────────────────────────────────
# 1. Set all env vars in Vercel / hosting dashboard
# 2. Never commit .env.production to git
# 3. Run: npx prisma db push (to sync any schema changes)
# 4. Run: npx prisma db seed (first deploy only)
# 5. Rotate NEXTAUTH_SECRET after first deployment
